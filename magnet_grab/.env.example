# magnet-grab configuration.
# Reuses the same Telegram bot as find-a-home — copy these two from your
# existing find-a-home .env (do NOT create a second bot).
TELEGRAM_BOT_TOKEN=123456:your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Shared secret. Required in the URL/query (?token=...) for every request,
# including the per-file download links. Pick a long random string.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
MAGNET_GRAB_TOKEN=change-me-to-a-long-random-string

# Public base URL your phone uses to reach the VPS. This is what the Telegram
# download links are built from, so it MUST be reachable from your phone
# (your VPS public IP or a domain). No trailing slash.
MAGNET_GRAB_PUBLIC_URL=http://YOUR_VPS_IP:8800

# Where torrents are written (each magnet gets its own infohash subfolder).
MAGNET_GRAB_DOWNLOAD_DIR=downloads

# Bind address / port for the built-in HTTP server.
MAGNET_GRAB_HOST=0.0.0.0
MAGNET_GRAB_PORT=8800

# Path to the aria2c binary (override only if it is not on PATH).
# MAGNET_GRAB_ARIA2C=aria2c

# Telegram magnet-trigger: when on (default), `serve` also long-polls Telegram,
# so you can just text a magnet link to the bot to start a download — no web
# page needed. Only messages from TELEGRAM_CHAT_ID are accepted. Set to false
# to disable and use the web form only.
# MAGNET_GRAB_TELEGRAM_POLL=true
