# Telegram is the recommended MVP alert channel.
# Create a bot with @BotFather, send it a message, then resolve your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional email fallback. Leave blank if you only want Telegram.
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
EMAIL_USE_TLS=true
