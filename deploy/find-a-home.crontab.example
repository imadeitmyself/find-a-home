# Foxtons and Savills. The lock prevents a slow run overlapping the next 5-minute slot.
*/5 * * * * cd /home/thibault/find-a-home && /usr/bin/flock -n /tmp/find-a-home-fast.lock venv/bin/python -m rental_alert_bot run --config config.json --once --schedule-group fast >> logs/cron-fast.log 2>&1

# Sources that have extracted candidates within the last 3 days.
3,18,33,48 * * * * cd /home/thibault/find-a-home && /usr/bin/flock -n /tmp/find-a-home-standard.lock venv/bin/python -m rental_alert_bot run --config config.json --once --schedule-group standard >> logs/cron-standard.log 2>&1

# Sources with no extracted candidates for 3 days.
13 * * * * cd /home/thibault/find-a-home && /usr/bin/flock -n /tmp/find-a-home-stale.lock venv/bin/python -m rental_alert_bot run --config config.json --once --schedule-group stale >> logs/cron-stale.log 2>&1

# Daily auto-update. One-shot cron jobs pick up the new code without restarting a service.
0 4 * * * cd /home/thibault/find-a-home && git pull --ff-only >> logs/deploy.log 2>&1 && venv/bin/pip install -e . -q >> logs/deploy.log 2>&1

# Daily fetch outcomes report at 07:30 UTC.
30 7 * * * cd /home/thibault/find-a-home && venv/bin/python -m rental_alert_bot daily-report --config config.json >> logs/daily-report.log 2>&1
