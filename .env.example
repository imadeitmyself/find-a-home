# Telegram — primary alert channel (listing matches + crawler health).
# Create a bot with @BotFather, send it a message, then resolve your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webshare residential proxy — used for Tier 1 agents (Foxtons, Dexters, Savills etc.)
# Credentials: Webshare dashboard → Proxy → Rotating Proxies → Credentials
WEBSHARE_PROXY_HOST=p.webshare.io
WEBSHARE_PROXY_PORT=80
WEBSHARE_PROXY_USER=
WEBSHARE_PROXY_PASS=
WEBSHARE_API_KEY=
# Alternative: set a single proxy URL directly (overrides WEBSHARE_* above)
# BROWSER_PROXY=http://user:pass@host:port

# Mailgun HTTP API — listing match emails sent to MAILGUN_TO.
# API key: Mailgun dashboard → API Keys
# Domain: Mailgun dashboard → Sending → Domains
# From: use postmaster@<your-sandbox-domain> for sandbox domains
# EU accounts: set MAILGUN_API_BASE=https://api.eu.mailgun.net
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=
MAILGUN_TO=thibb.home@gmail.com
# MAILGUN_API_BASE=https://api.mailgun.net  # default; change to eu if needed
